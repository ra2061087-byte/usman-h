{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Student profile information",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "Auto-generated unique ID" },
        "name": { "type": "string" },
        "fatherName": { "type": "string" },
        "caste": { "type": "string" },
        "age": { "type": "number" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "gmail": { "type": "string" },
        "admissionDate": { "type": "string", "format": "date" },
        "referenceNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "name", "fatherName", "admissionDate"]
    },
    "AcademicRecord": {
      "title": "Academic Record",
      "description": "Daily educational progress for a student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "sabaqi": { "type": "string", "description": "Lessons" },
        "sabqi": { "type": "string" },
        "manzil": { "type": "string" },
        "duas": { "type": "string" },
        "namaz": { "type": "object", "description": "Record of five daily prayers" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "date"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance for a student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent", "leave"] }
      },
      "required": ["studentId", "date", "status"]
    },
    "Income": {
      "title": "Income",
      "description": "Finance income records",
      "type": "object",
      "properties": {
        "donorName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "purpose": { "type": "string" }
      },
      "required": ["donorName", "amount", "date"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Finance expense records",
      "type": "object",
      "properties": {
        "details": { "type": "string" },
        "amount": { "type": "number" },
        "purpose": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["details", "amount", "purpose", "date"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Users with admin privileges",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "Student",
      "description": "All student profile documents"
    },
    "/academic_records/{recordId}": {
      "schema": "AcademicRecord",
      "description": "Daily progress records indexed by student and date"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Daily attendance records"
    },
    "/income/{incomeId}": {
      "schema": "Income",
      "description": "Income logs"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Expense logs"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Authorized admin users"
    }
  }
}
